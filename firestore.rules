rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isHouseholdMember(householdId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    // Perfil do usuário: só ele mesmo lê/escreve o próprio
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Household: qualquer membro pode ler; escrita restrita
    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      allow write: if isSignedIn(); // refinar depois (ex: só owner remove membros)
    }

    // Listas de compra: qualquer membro da household lê e escreve
    match /households/{householdId}/shopping/{itemId} {
      allow read, write: if isHouseholdMember(householdId);
    }

    // Configuração do Home Assistant (URL + long-lived token).
    // Fica aqui em vez de numa variável VITE_ justamente para NÃO ir
    // para o bundle público do site. Só membros autenticados da
    // household conseguem ler ou alterar.
    match /households/{householdId}/config/{docId} {
      allow read, write: if isHouseholdMember(householdId);
    }

    // Agenda: dono escreve; outros membros da mesma household só leem
    match /users/{userId}/calendarCache/{eventId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == userId ||
         get(/databases/$(database)/documents/users/$(userId)).data.householdId ==
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId);
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Email: 100% privado, nunca compartilhado
    match /users/{userId}/emailCache/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Histórico de conversa com a ARIA: 100% privado (pode conter dados
    // pessoais, e-mails resumidos, endereços, etc.) — nunca compartilhado
    // com o cônjuge, mesmo estando na mesma household.
    match /users/{userId}/ariaConversation/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
